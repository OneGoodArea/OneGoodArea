# env/local/postgres.env.example -- container/postgres image, local (Plan 008).
#
# Copy to env/local/postgres.env (gitignored) and fill in real values.
# Loaded via: make container-run ENV=local SERVICE=postgres
#
# The same DSN must be reflected in env/local/api.env DATABASE_URL and
# env/local/web.env DATABASE_URL.

POSTGRES_DB=oga
POSTGRES_USER=oga
POSTGRES_PASSWORD=change-me

# Optional: where postgres stores its on-disk data. Default is the image's
# /var/lib/postgresql/data. Override to point at a host volume in a wrapper
# orchestrator (`-v oga-pg-data:/var/lib/postgresql/data`).
# PGDATA=/var/lib/postgresql/data
