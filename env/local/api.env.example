# env/local/api.env.example -- apps/api running locally
#
# Copy to env/local/api.env (gitignored) and fill in real values.
# All env vars are documented at infrastructure/config/index.ts.
# Plan 012: AR-205 API Environment Variable Audit & Centralisation.

# --- runtime --------------------------------------------------------
NODE_ENV=development
PORT=8080
HOST=0.0.0.0

# --- database -------------------------------------------------------
# Points at the local container/postgres image when running locally.
DATABASE_URL=postgres://oga:change-me@host.containers.internal:5432/oga

# --- auth bridge (apps/web <-> apps/api JWT) -----------------------
# MUST match apps/web AUTH_SECRET, otherwise the BFF proxy 401s.
AUTH_SECRET=replace-me

# --- public frontend origin (Stripe redirects, APP_URL) ------------
NEXTAUTH_URL=http://localhost:3000

# --- providers (AI narration & email) --------------------------------
OGA_AI_PROVIDER=mock
OGA_EMAIL_PROVIDER=mailhog

# Real provider keys -- leave blank for full mock mode.
ANTHROPIC_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
RESEND_API_KEY=

# --- Stripe price IDs (V1 legacy — grandfathered) ------------------
# Required if V1 plans (starter / pro) have active Stripe subscriptions.
STRIPE_STARTER_PRICE_ID=
STRIPE_PRO_PRICE_ID=

# V1 legacy — safe to omit locally (hardcoded live fallbacks)
STRIPE_DEVELOPER_PRICE_ID=
STRIPE_BUSINESS_PRICE_ID=
STRIPE_GROWTH_PRICE_ID=

# --- Stripe price IDs (V2 active) -----------------------------------
# Safe to omit locally; hardcoded live fallbacks are LIVE Stripe IDs.
# Override with TEST mode price IDs when running billing flows locally.
STRIPE_STARTER_V2_PRICE_ID=
STRIPE_BUILD_PRICE_ID=
STRIPE_BUILD_ANNUAL_PRICE_ID=
STRIPE_SCALE_PRICE_ID=
STRIPE_SCALE_ANNUAL_PRICE_ID=
STRIPE_GROWTH_V2_PRICE_ID=
STRIPE_GROWTH_V2_ANNUAL_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=
STRIPE_MCP_ADDON_PRICE_ID=

# --- feature flags (signal-first) -----------------------------------
OGA_SIGNALS_API=true
OGA_SIGNALS_STORE_READ=true

# --- cron protection ------------------------------------------------
# Required by GET /cron/rescore (CRON_SECRET-gated).
CRON_SECRET=replace-me

# --- logging --------------------------------------------------------
OGA_LOG_LEVEL=debug
OGA_LOCAL_RUNTIME_ENABLED=true

# --- mock AI knobs (only active when OGA_AI_PROVIDER=mock) --------
OGA_MOCK_AI_FORCE_FAILURE=false
OGA_MOCK_AI_LATENCY_MS=0
OGA_MOCK_AI_TOKEN_LIMIT=4096
OGA_MOCK_AI_RATE_LIMIT_EVERY_N=0

# --- eval script gate -----------------------------------------------
OGA_EVAL_PLAN=false
