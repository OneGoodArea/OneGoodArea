# env/local/api.env.example -- apps/api running locally (Plan 008).
#
# Copy to env/local/api.env (gitignored) and fill in real values.
# Loaded via: make container-run ENV=local SERVICE=api
#
# Ownership: every var below is read by apps/api process.env directly.
# See apps/api/src/infrastructure/config/index.ts for the typed boundary.

# --- runtime --------------------------------------------------------
NODE_ENV=development
PORT=8080

# --- database -------------------------------------------------------
# Points at the local container/postgres image when running locally.
DATABASE_URL=postgres://oga:change-me@host.containers.internal:5432/oga

# --- auth bridge (apps/web <-> apps/api JWT) ------------------------
# MUST match apps/web AUTH_SECRET, otherwise the BFF proxy 401s.
AUTH_SECRET=replace-me

# --- public frontend origin (Stripe redirects, APP_URL) -------------
NEXTAUTH_URL=http://localhost:3000

# --- providers ------------------------------------------------------
OGA_AI_PROVIDER=mock
OGA_EMAIL_PROVIDER=mailhog

# Real provider keys -- leave blank for full mock mode.
ANTHROPIC_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
RESEND_API_KEY=

# --- feature flags (signal-first) -----------------------------------
OGA_SIGNALS_API=true
OGA_SIGNALS_STORE_READ=true

# --- cron protection ------------------------------------------------
# Required by GET /cron/rescore (CRON_SECRET-gated).
CRON_SECRET=replace-me
