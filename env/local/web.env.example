# env/local/web.env.example -- apps/web running in docker container (Plan 011).
#
# Copy to env/local/web.env (gitignored) and fill in real values.
# Used by: make web-up-external, make web-up-local
#
# The web container is a stateless HTTP client to the API. Set INTERNAL_API_URL
# to point to your API location (see scenarios below).

# --- runtime --------------------------------------------------------
NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0

# --- auth -----------------------------------------------------------
# MUST match apps/api AUTH_SECRET.
AUTH_SECRET=replace-me
NEXTAUTH_URL=http://localhost:3000

# --- API connection -------------------------------------------------
# Set ONE of these depending on where your API runs:
#
# API as local container (oga-api):
#   INTERNAL_API_URL=http://oga-api:8080
#   → requires: make db-net api-run (API on oga-network)
#   → use: make web-up-local
#
# API as bare process on same host:
#   INTERNAL_API_URL=http://host.containers.internal:8080
#   → use: make web-up-external
#
# API on LAN:
#   INTERNAL_API_URL=http://192.168.1.50:8080
#   → use: make web-up-external
#
# API on Oracle Cloud / VPS:
#   INTERNAL_API_URL=https://api.yourdomain.com
#   → use: make web-up-external
#
INTERNAL_API_URL=http://host.containers.internal:8080
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- providers (optional for local container testing) ----------------
STRIPE_PUBLISHABLE_KEY=pk_test_replace-me
STRIPE_WEBHOOK_SECRET=whsec_replace-me

# --- observability (leave blank for local) --------------------------
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_SENTRY_DSN=
