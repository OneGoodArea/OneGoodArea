# env/local/web.env.example -- apps/web running locally (Plan 008).
#
# Copy to env/local/web.env (gitignored) and fill in real values.
# Loaded via: make container-run ENV=local SERVICE=web
#
# Plan 010 will migrate apps/web's remaining direct DB callers behind the BFF;
# until then, DATABASE_URL is still required here.

# --- runtime --------------------------------------------------------
NODE_ENV=development
PORT=3000
HOSTNAME=0.0.0.0

# --- database (interim -- see Plan 010) -----------------------------
DATABASE_URL=postgres://oga:change-me@host.containers.internal:5432/oga

# --- auth -----------------------------------------------------------
# MUST match apps/api AUTH_SECRET.
AUTH_SECRET=replace-me
NEXTAUTH_URL=http://localhost:3000

# --- BFF target (apps/api origin) -----------------------------------
INTERNAL_API_URL=http://host.containers.internal:8080
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- providers (shared with API for now) ----------------------------
ANTHROPIC_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
RESEND_API_KEY=

# --- observability (build-time + runtime; safe to leave blank) ------
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_SENTRY_DSN=
