# env/local/web.env.example -- apps/web running in docker container (Plan 011).
#
# Copy to env/local/web.env (gitignored) and fill in real values.
# Used by: make web-up, make stack-up-min, make stack-up-full
#
# The web container is a stateless HTTP client to the API. Set INTERNAL_API_URL
# to point to your API location (see scenarios below).

# --- runtime --------------------------------------------------------
NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0

# --- auth -----------------------------------------------------------
# MUST match apps/api AUTH_SECRET.
AUTH_SECRET=replace-me
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=replace-me
GOOGLE_CLIENT_SECRET=replace-me
GITHUB_CLIENT_ID=replace-me
GITHUB_CLIENT_SECRET=replace-me

# --- cron -----------------------------------------------------------
CRON_SECRET=replace-me

# --- API connection -------------------------------------------------
# For compose-native local stack, keep this as http://api:8080.
INTERNAL_API_URL=http://api:8080
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- providers (optional for local container testing) ----------------
STRIPE_PUBLISHABLE_KEY=pk_test_replace-me
STRIPE_WEBHOOK_SECRET=whsec_replace-me

# --- Stripe price IDs (test) ----------------------------------------
# V1 legacy (no fallback — required even for local Stripe testing)
STRIPE_STARTER_PRICE_ID=price_test_replace_me
STRIPE_PRO_PRICE_ID=price_test_replace_me
# V1 legacy (have hardcoded prod fallbacks in stripe.ts)
STRIPE_DEVELOPER_PRICE_ID=price_test_replace_me
STRIPE_BUSINESS_PRICE_ID=price_test_replace_me
STRIPE_GROWTH_PRICE_ID=price_test_replace_me
# V2 active (have hardcoded prod fallbacks in stripe.ts)
STRIPE_STARTER_V2_PRICE_ID=price_test_replace_me
STRIPE_BUILD_PRICE_ID=price_test_replace_me
STRIPE_BUILD_ANNUAL_PRICE_ID=price_test_replace_me
STRIPE_SCALE_PRICE_ID=price_test_replace_me
STRIPE_SCALE_ANNUAL_PRICE_ID=price_test_replace_me
STRIPE_GROWTH_V2_PRICE_ID=price_test_replace_me
STRIPE_GROWTH_V2_ANNUAL_PRICE_ID=price_test_replace_me
STRIPE_ENTERPRISE_PRICE_ID=price_test_replace_me
# Add-ons
STRIPE_MCP_ADDON_PRICE_ID=price_test_replace_me

# --- runtime config -------------------------------------------------
OGA_LOCAL_RUNTIME_ENABLED=true
OGA_SERVICE_MODE=local-test
OGA_LOG_LEVEL=debug
OGA_AI_PROVIDER=anthropic
OGA_EMAIL_PROVIDER=resend
POSTCODES_API_BASE_URL=https://api.postcodes.io

# --- observability (leave blank for local) --------------------------
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_SENTRY_DSN=
