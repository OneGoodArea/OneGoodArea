# env/dev/api.env.example -- apps/api in dev/staging (Plan 008).
#
# Copy to env/dev/api.env (gitignored) and fill in real values.
# Loaded via: make container-run ENV=dev SERVICE=api
#
# Dev points at a Neon dev branch + Stripe TEST keys + Anthropic dev key.
# Real Anthropic / Stripe responses, isolated database, safe to break.

# --- runtime --------------------------------------------------------
NODE_ENV=production
PORT=8080

# --- database -------------------------------------------------------
# Neon dev branch (Neon CLI: `neonctl branches create --name dev`).
DATABASE_URL=postgres://USER:PASSWORD@HOST.neon.tech/oga?sslmode=require

# --- auth bridge ----------------------------------------------------
AUTH_SECRET=replace-me

# --- public frontend origin -----------------------------------------
NEXTAUTH_URL=https://dev.onegoodarea.com

# --- providers ------------------------------------------------------
OGA_AI_PROVIDER=anthropic
OGA_EMAIL_PROVIDER=resend

ANTHROPIC_API_KEY=replace-me
# Stripe TEST mode keys in dev.
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_test_replace_me
RESEND_API_KEY=replace-me

# --- feature flags --------------------------------------------------
OGA_SIGNALS_API=true
OGA_SIGNALS_STORE_READ=true

# --- cron protection ------------------------------------------------
CRON_SECRET=replace-me
