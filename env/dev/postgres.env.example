# env/dev/postgres.env.example -- container/postgres image, dev (Plan 008).
#
# Dev rarely uses the container postgres -- the Neon dev branch is the source
# of truth. This file exists for parity (offline integration tests against a
# dev-shaped DB) and so the matrix has no holes.

POSTGRES_DB=oga
POSTGRES_USER=oga
POSTGRES_PASSWORD=replace-me
# PGDATA=/var/lib/postgresql/data
