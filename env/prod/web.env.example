# env/prod/web.env.example -- apps/web in production (Plan 008).
#
# PRIMARY runtime for apps/web is Vercel -- this image exists for parity /
# backup hosting. On Vercel, env vars come from the project dashboard, NOT
# from this file. Use this template only when running the container image
# directly (local prod-mirror, CI smoke, backup host).

# --- runtime --------------------------------------------------------
NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0

# --- database (interim -- see Plan 010) -----------------------------
DATABASE_URL=

# --- auth -----------------------------------------------------------
AUTH_SECRET=
NEXTAUTH_URL=https://www.onegoodarea.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- cron -----------------------------------------------------------
CRON_SECRET=

# --- BFF target -----------------------------------------------------
INTERNAL_API_URL=https://onegoodarea.onrender.com
NEXT_PUBLIC_APP_URL=https://www.onegoodarea.com

# --- providers ------------------------------------------------------
ANTHROPIC_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
RESEND_API_KEY=

# --- Stripe price IDs (live) ----------------------------------------
# V1 legacy (no fallback — required)
STRIPE_STARTER_PRICE_ID=
STRIPE_PRO_PRICE_ID=
# V1 legacy (have hardcoded prod fallbacks in stripe.ts — override here for custom pricing)
STRIPE_DEVELOPER_PRICE_ID=
STRIPE_BUSINESS_PRICE_ID=
STRIPE_GROWTH_PRICE_ID=
# V2 active (have hardcoded prod fallbacks in stripe.ts — override here for custom pricing)
STRIPE_STARTER_V2_PRICE_ID=
STRIPE_BUILD_PRICE_ID=
STRIPE_BUILD_ANNUAL_PRICE_ID=
STRIPE_SCALE_PRICE_ID=
STRIPE_SCALE_ANNUAL_PRICE_ID=
STRIPE_GROWTH_V2_PRICE_ID=
STRIPE_GROWTH_V2_ANNUAL_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=
# Add-ons
STRIPE_MCP_ADDON_PRICE_ID=

# --- observability --------------------------------------------------
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_SENTRY_DSN=
