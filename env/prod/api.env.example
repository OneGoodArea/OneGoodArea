# env/prod/api.env.example -- apps/api in production (Plan 008).
#
# Production secrets MUST be set in the host platform (Render dashboard, k8s
# Secret, Cloud Run Secret Manager). NEVER fill real values into a committed
# file. This template documents the contract; the real env/prod/api.env stays
# off git.
#
# Loaded via: make container-run ENV=prod SERVICE=api (only for local
# prod-mirror smoke tests -- prod itself reads from the host platform).

# --- runtime --------------------------------------------------------
NODE_ENV=production
# PORT is injected by the host platform (Render, Cloud Run, Koyeb).
# Local override only when running the image directly.
PORT=8080

# --- database -- prod Neon -----------------------------------------
# SET IN HOST PLATFORM. Do not commit.
DATABASE_URL=

# --- auth bridge ----------------------------------------------------
AUTH_SECRET=

# --- public frontend origin -----------------------------------------
NEXTAUTH_URL=https://www.onegoodarea.com

# --- providers ------------------------------------------------------
OGA_AI_PROVIDER=anthropic
OGA_EMAIL_PROVIDER=resend

ANTHROPIC_API_KEY=
# Stripe LIVE mode keys in prod.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
RESEND_API_KEY=

# --- feature flags --------------------------------------------------
OGA_SIGNALS_API=true
OGA_SIGNALS_STORE_READ=true

# --- cron protection ------------------------------------------------
CRON_SECRET=
