# testing — generated artifacts (vitest reports + coverage). Plan 007
# phase 0 routes all of these under /.artifacts/test-reports/ at repo
# root; per-workspace tools (apps/api, apps/web, packages/contracts)
# write into .artifacts/test-reports/<workspace>/. The .gitkeep
# placeholder keeps the directory tracked so it survives git clean +
# fresh clones; everything else inside is ignored.
/.artifacts/*
!/.artifacts/.gitkeep
# next.js (app now lives at apps/web; keep these unanchored so the workspace's
# build output is ignored too)
.next/
/out/
apps/web/out/

# production
# (legacy CRA-style /build ignore removed Plan 008 -- this monorepo emits
#  build artifacts to .next/, apps/api/dist/, and .artifacts/, never /build.
#  /build/ now holds Make includes -- see build/container.mk.)

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# env files
.env*.local
.env
.env.local.test
.env.local.test.secrets
*.secrets
vercel-import.env
# Plan 008: env/<env>/<service>.env are real, filled-in env files; only the
# *.env.example templates are tracked.
env/**/*.env
!env/**/*.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
tsconfig.tsbuildinfo
