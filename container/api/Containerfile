# Portable container for the standalone backend (apps/api, Fastify).
#
# This is the universal deploy artifact: the same image runs on ANY OCI host —
# Render, Google Cloud Run, Koyeb, Fly, or a plain VM — so switching providers
# is zero-rework. Build context is the repo ROOT (monorepo); see .dockerignore.
#
# The server is BUNDLED to a single CJS file with esbuild at build time and run
# with plain `node` (NOT tsx). Running tsx in prod transpiled the whole TS import
# graph on every cold start, which on a small free-tier instance (0.1 CPU/512MB)
# was too slow/heavy to bind a port in time. The prebuilt bundle boots in
# milliseconds with low memory.
#
# Plan 017: MULTI-STAGE — build stage does full install (needed for test target)
# + esbuild bundle; runtime stage does its own slim `npm install --omit=dev`
# and carries only dist/server.cjs + slim node_modules + curl.
# compose.test.yml targets the `build` stage for tests (full source + deps).

# --- BUILD STAGE ----------------------------------------------------------
# Full npm install — includes devDeps so this stage can also serve as the
# api-test target in compose.test.yml. The runtime stage below does its own
# slim install, so the full node_modules here are never shipped to prod.
FROM node:22-slim AS build
WORKDIR /app

# No NODE_ENV=production here — npm with that env omits devDeps even without
# --omit=dev, and we need esbuild/tsx (now devDependencies) for the build.
# The runtime stage below sets NODE_ENV=production for its slim install.

# Manifests first (layer caching). Every declared workspace's package.json must
# be present to resolve the workspace tree, hence apps/web's manifest is copied
# even though its source is not (the API does not run it).
COPY package.json package-lock.json ./
COPY apps/api/package.json ./apps/api/
COPY apps/web/package.json ./apps/web/
COPY packages/contracts/package.json ./packages/contracts/

# `npm install`, not `npm ci`: the lockfile is generated on Windows and is missing
# Linux-only optional deps (e.g. @emnapi/* pulled by Tailwind's native bindings),
# which makes `npm ci` fail the strict in-sync check on the Linux build host.
# `npm install` resolves the platform deps.
# Full install (no --omit=dev) so this stage doubles as the api-test target.
RUN npm install --no-audit --no-fund

# Only the backend + its shared contracts source (NOT apps/web source).
COPY packages/contracts ./packages/contracts
COPY apps/api ./apps/api

# Bundle the server to dist/server.cjs. esbuild inlines all reachable JS
# and workspace source, so no TypeScript or workspace resolution is needed
# at runtime.
RUN npm run build -w @onegoodarea/api

# --- RUNTIME STAGE --------------------------------------------------------
FROM node:22-slim AS runtime
WORKDIR /app

ENV NODE_ENV=production
# Hosts (Render/Cloud Run/Koyeb) inject PORT; 8080 is the default for local runs.
ENV PORT=8080

# Install curl for healthchecks (Plan 011 / Plan 017).
RUN apt-get update && apt-get install -y --no-install-recommends curl \
    && rm -rf /var/lib/apt/lists/*

# Manifests needed for the slim `npm install --omit=dev` below.
COPY package.json package-lock.json ./
COPY apps/api/package.json ./apps/api/
COPY apps/web/package.json ./apps/web/
COPY packages/contracts/package.json ./packages/contracts/

# Slim install — production deps only. The esbuild bundle inlines most JS,
# but native modules (@neondatabase/serverless WASM) are loaded at runtime.
RUN npm install --omit=dev --no-audit --no-fund

# Copy the esbuild bundles and static assets (swagger-ui).
COPY --from=build /app/apps/api/dist/server.cjs ./apps/api/dist/server.cjs
COPY --from=build /app/apps/api/dist/migrate.cjs ./apps/api/dist/migrate.cjs
COPY --from=build /app/apps/api/dist/static ./apps/api/dist/static

EXPOSE 8080

# AR-380: apply DDL on every container start before booting the server.
# Migrations are idempotent (CREATE TABLE IF NOT EXISTS, ADD COLUMN
# IF NOT EXISTS, DROP TABLE IF EXISTS, CREATE OR REPLACE VIEW), so
# running them on every restart is safe + cheap (<1s for the full
# registry locally). If migrate exits non-zero, the && short-circuits
# and the server never starts — Render flags the deploy as failed
# instead of running new code against stale schema. Reads DATABASE_URL
# from the runtime env.
CMD ["sh", "-c", "node apps/api/dist/migrate.cjs && node apps/api/dist/server.cjs"]
