{
  "name": "@onegoodarea/api",
  "version": "0.0.0",
  "private": true,
  "description": "OneGoodArea standalone backend API (Fastify). The sole custodian of DB, scoring engine, and external integrations once Phase 1+ migrations land. Phase 0: scaffold only.",
  "type": "module",
  "main": "./src/server.ts",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "bootstrap:test-key": "tsx src/scripts/bootstrap-test-key.ts",
    "build": "esbuild src/server.ts --bundle --platform=node --format=cjs --outfile=dist/server.cjs --target=node22",
    "start:prod": "node dist/server.cjs",
    "migrate": "tsx src/infrastructure/db/migrate.ts",
    "refresh:deprivation": "tsx src/modules/signals/refresh/deprivation.ts",
    "refresh:prices": "tsx src/modules/signals/refresh/prices.ts",
    "refresh:crime": "tsx src/modules/signals/refresh/crime.ts",
    "refresh:peers": "tsx src/modules/signals/refresh/peers-refresh.ts",
    "derive:signals": "tsx src/modules/signals/refresh/derive.ts",
    "normalize:deprivation": "tsx src/modules/signals/refresh/normalize.ts",
    "normalize:signals": "tsx src/modules/signals/refresh/normalize-all.ts",
    "timeseries:append": "tsx src/modules/signals/refresh/timeseries.ts",
    "eval:intelligence": "tsx src/modules/intelligence/eval/run.ts",
    "load:geo": "tsx src/modules/signals/refresh/geo-spine.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.2",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@neondatabase/serverless": "^1.1.0",
    "@onegoodarea/contracts": "*",
    "fastify": "^5.2.0",
    "jose": "^6.2.3",
    "resend": "^6.12.3",
    "stripe": "^20.4.0"
  },
  "devDependencies": {
    "@types/node": "^25",
    "esbuild": "^0.28.0",
    "msw": "^2.14.6",
    "tsx": "^4.19.2"
  }
}
