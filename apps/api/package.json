{
  "name": "@onegoodarea/api",
  "version": "0.0.0",
  "private": true,
  "description": "OneGoodArea standalone backend API (Fastify). The sole custodian of DB, scoring engine, and external integrations once Phase 1+ migrations land. Phase 0: scaffold only.",
  "type": "module",
  "main": "./src/server.ts",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "migrate": "tsx src/infrastructure/db/migrate.ts",
    "refresh:deprivation": "tsx src/modules/signals/refresh/deprivation.ts",
    "normalize:deprivation": "tsx src/modules/signals/refresh/normalize.ts",
    "timeseries:append": "tsx src/modules/signals/refresh/timeseries.ts",
    "load:geo": "tsx src/modules/signals/refresh/geo-spine.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "fastify": "^5.2.0",
    "@neondatabase/serverless": "^1.1.0",
    "@anthropic-ai/sdk": "^0.95.2",
    "@onegoodarea/contracts": "*",
    "jose": "^6.2.3",
    "resend": "^6.12.3",
    "stripe": "^20.4.0",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "@types/node": "^25",
    "msw": "^2.14.6"
  }
}
