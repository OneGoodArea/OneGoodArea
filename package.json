{
  "name": "areaiq",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @onegoodarea/web",
    "build": "npm run build --workspaces --if-present",
    "start": "npm run start -w @onegoodarea/web",
    "stop": "pkill -f 'next dev' || echo 'No dev server running'",
    "local:test:start": "./apps/web/scripts/runtime-up.sh",
    "local:test:stop": "./apps/web/scripts/runtime-down.sh",
    "local:test:reset": "./apps/web/scripts/runtime-reset.sh",
    "local:test:seed": "./apps/web/scripts/runtime-seed.sh",
    "lint": "eslint apps packages",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:coverage": "npm run test:coverage -w @onegoodarea/web",
    "test:api": "./test_files/simple-run.sh"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "msw": "^2.14.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.0"
  }
}
